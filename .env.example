# =========================================================================
# degeneratr — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =========================================================================

# ---- Provider selection -------------------------------------------------
# Which market-data provider to use. Currently: "tiger".
MARKET_DATA_PROVIDER=tiger
# Which broker/execution provider to use. One of: "moomoo", "paper".
BROKER_PROVIDER=paper

# ---- Tiger Brokers (market data) ----------------------------------------
# Your Tiger developer ID (numeric string from the Tiger OpenAPI portal).
TIGER_ID=
# Paper and live account numbers. The active one is selected by TIGER_TRADE_ENV.
TIGER_PAPER_ACCOUNT=
TIGER_LIVE_ACCOUNT=
# Optional generic fallback account, used only if the env-specific one is blank.
TIGER_ACCOUNT=
# Absolute path to your RSA private key file (PKCS#1, .pem) used to sign requests.
TIGER_PRIVATE_KEY_PATH=
# Trading environment for Tiger data/account context: PAPER or LIVE.
TIGER_TRADE_ENV=PAPER

# ---- MooMoo / Futu (execution) ------------------------------------------
# Host where the local OpenD gateway process is listening.
MOOMOO_HOST=127.0.0.1
# Port the OpenD gateway exposes (default 11111).
MOOMOO_PORT=11111
# Security firm: FUTUSECURITIES, FUTUINC, or FUTUSG (your account's firm).
MOOMOO_SECURITY_FIRM=FUTUINC
# 6-digit trade-unlock password. Required before any order can be placed.
MOOMOO_UNLOCK_TRADE=
# Execution environment: REAL (live money) or SIMULATE (built-in paper trading).
MOOMOO_TRADE_ENV=SIMULATE

# ---- Risk limits --------------------------------------------------------
# Max dollar loss tolerated on a single trade before it is force-closed.
RISK_MAX_LOSS_PER_TRADE=250
# Max cumulative dollar loss for one trading day; trips the kill-switch.
RISK_MAX_DAILY_LOSS=1000
# Max absolute net delta exposure (delta × contracts × 100). 0DTE scalping runs
# high intraday delta, so keep this generous; lower it to curb leverage.
RISK_MAX_DELTA_EXPOSURE=2500
# Fraction of account equity to risk per position (0.02 = 2%).
RISK_PER_TRADE_FRACTION=0.02

# ---- Backtester ---------------------------------------------------------
# Commission charged per option contract (USD). Tiger/MooMoo typical ~0.65.
COMMISSION_PER_CONTRACT=0.65
# Starting cash for backtest runs (USD).
BACKTEST_STARTING_CASH=25000

# ---- Data store & caching -----------------------------------------------
# Tickers captured by `backfill` and swept by default (comma-separated).
WATCHLIST=SPY,QQQ,AAPL,AMD,NVDA,MU
# In-memory TTL (seconds) for live bar fetches. Historical bars don't change,
# so repeated backtests reuse them. 0 disables caching.
BAR_CACHE_TTL=300

# ---- Telegram notifications ---------------------------------------------
# Push alerts (signal triggered, position opened/closed, end-of-day summary) to
# a Telegram chat. Setup:
#   1. In Telegram, message @BotFather → /newbot → copy the HTTP API token below.
#   2. Send any message to your new bot, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy the numeric
#      "chat":{"id": ...} → that's TELEGRAM_CHAT_ID.
#   3. Set TELEGRAM_ENABLED=true, then `python -m degeneratr watch --test` to verify.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Master switch: when true, `serve` auto-starts the watcher; `watch` runs it standalone.
TELEGRAM_ENABLED=false
# Seconds between watcher polls during market hours.
WATCH_INTERVAL_SECONDS=20

# ---- Misc ---------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
